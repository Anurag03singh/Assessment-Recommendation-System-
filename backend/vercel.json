{
  "version": 2,
  "builds": [
    {
      "src": "main_production.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "50mb"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "main_production.py"
    }
  ],
  "env": {
    "PYTHON_VERSION": "3.11",
    "USE_LITE_MODE": "true",
    "SKIP_RERANKING": "false"
  }
}
